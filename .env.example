# Database (local docker-compose defaults)
INSYT_DATABASE_URL=postgresql+asyncpg://insyt:insyt@localhost:5432/insyt
INSYT_DATABASE_URL_SYNC=postgresql://insyt:insyt@localhost:5432/insyt

# Redis
INSYT_REDIS_URL=redis://localhost:6379/0

# Anthropic (required)
INSYT_ANTHROPIC_API_KEY=sk-ant-...

# Ingestion APIs
INSYT_SERPER_API_KEY=
INSYT_TWITTER_API_KEY=
INSYT_YOUTUBE_API_KEY=
INSYT_GOOGLE_PLACES_API_KEY=

# App
INSYT_ENVIRONMENT=development
INSYT_LOG_LEVEL=INFO
INSYT_CLIENT_NAME=kalyan

# Frontend
INSYT_FRONTEND_URL=http://localhost:3000

# Frontend env (for Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
